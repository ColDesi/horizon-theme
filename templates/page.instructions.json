    "custom_liquid_gRHAKw": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<section class=\"octo-instructions\">\n  <div class=\"octo-instructions__wrap\">\n\n    <div class=\"octo-hero\">\n      <p class=\"octo-eyebrow\">APPLICATION GUIDE</p>\n      <h1>How to Apply Your OctoPatch</h1>\n      <p>Simple heat press instructions for hats, jackets, bags, and more.</p>\n    </div>\n\n    <div class=\"octo-card octo-card--main\">\n      <div class=\"octo-card__copy\">\n        <p class=\"octo-eyebrow\">CAP PRESS</p>\n        <h2>Applying patches to hats</h2>\n        <p>\n          For hats and caps, use a cap press so the patch sits cleanly against the curved surface.\n          Position the patch, cover it with a protective sheet, press, and let it cool before handling.\n        </p>\n      </div>\n\n      <div class=\"octo-card__image\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0834/8562/2516/files/Cap_Press_Instructions.png?v=1783365181\" alt=\"Cap press instructions for applying patches to hats\">\n      </div>\n    </div>\n\n    <div class=\"octo-steps\">\n      <div class=\"octo-step\">\n        <span>1</span>\n        <h3>Position</h3>\n        <p>Place your patch where you want it. Make sure it is straight before pressing.</p>\n      </div>\n\n      <div class=\"octo-step\">\n        <span>2</span>\n        <h3>Press</h3>\n        <p>Use firm, even pressure with a heat press at 320°F for 15 seconds using medium pressure.</p>\n      </div>\n\n      <div class=\"octo-step\">\n        <span>3</span>\n        <h3>Cool</h3>\n        <p>Let the patch cool before handling, flexing, wearing, or washing.</p>\n      </div>\n    </div>\n\n    <div class=\"octo-card octo-card--fun\">\n      <div class=\"octo-card__copy\">\n        <p class=\"octo-eyebrow\">THE OCTO WAY</p>\n        <h2>Made for more than one style</h2>\n        <p>\n          Jackets, hats, bags, uniforms, and more. OctoPatches are built for flexible customization across different materials, shapes, and designs.\n        </p>\n      </div>\n\n      <div class=\"octo-card__image\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0834/8562/2516/files/octo_making_a_jacket_with_press.png?v=1783367456\" alt=\"OctoPatches octopus using a heat press on a jacket\">\n      </div>\n    </div>\n\n    <div class=\"octo-section-heading\">\n      <p class=\"octo-eyebrow\">TROUBLESHOOTING</p>\n      <h2>Having trouble?</h2>\n    </div>\n\n    <div class=\"octo-troubleshooting\">\n      <div>\n        <h3>Patch edges lifting</h3>\n        <p>Increase pressure slightly and repress with a protective sheet. Make sure the garment surface is flat and clean.</p>\n      </div>\n\n      <div>\n        <h3>Patch is not bonding</h3>\n        <p>Check that you are using enough pressure and the correct press type. Hats usually need a cap press, not a flat press.</p>\n      </div>\n\n      <div>\n        <h3>Patch shifted while pressing</h3>\n        <p>Recheck placement before pressing. Use heat-safe tape when needed to hold the patch in place.</p>\n      </div>\n\n      <div>\n        <h3>Garment looks marked</h3>\n        <p>Use a protective sheet and test first on delicate fabrics. Some materials need lower pressure or extra care.</p>\n      </div>\n    </div>\n\n    <div class=\"octo-section-heading\">\n      <p class=\"octo-eyebrow\">FAQS</p>\n      <h2>Frequently asked questions</h2>\n    </div>\n\n    <div class=\"octo-faq\">\n      <details open>\n        <summary>Can I apply OctoPatches to hats?</summary>\n        <p>Yes. For best results, use a cap press so the patch follows the curve of the hat.</p>\n      </details>\n\n      <details>\n        <summary>Can I use a regular iron?</summary>\n        <p>A heat press is strongly recommended. Household irons usually do not provide consistent pressure or heat. However, if you carefully control the time, pressure, and use no steam, you can successfully apply a patch with a household iron. Longevity may be compromised due to the lack of consistent pressure, especially on caps. </p>\n      </details>\n\n      <details>\n        <summary>Do I need to sew the patch on?</summary>\n        <p>No. OctoPatches are designed to be heat applied. </p>\n      </details>\n\n      <details>\n        <summary>When and How can I wash the item?</summary>\n        <p>For best results, wait 24 hours before washing. Ideally wash inside out and avoid high dryer heat.</p>\n      </details>\n\n      <details>\n        <summary>What items can I apply them to?</summary>\n        <p>They work well on hats, jackets, hoodies, bags, uniforms, and many other fabric items. Always test specialty materials first. Patches are recommended heavier items. Not for t-shirt and other very lightweight fabrics. </p>\n      </details>\n    </div>\n\n  </div>\n</section>\n\n<style>\n  .octo-instructions {\n    background:\n      radial-gradient(circle at top right, rgba(255,106,19,.16), transparent 34%),\n      linear-gradient(180deg, #05070a 0%, #0b1016 100%);\n    color: #fff;\n    padding: 80px 24px;\n  }\n\n  .octo-instructions__wrap {\n    max-width: 1450px;\n    margin: 0 auto;\n  }\n\n  .octo-hero,\n  .octo-section-heading {\n    text-align: center;\n    max-width: 950px;\n    margin: 0 auto 44px;\n  }\n\n  .octo-eyebrow {\n    color: #FF6A13;\n    font-size: 15px;\n    font-weight: 900;\n    letter-spacing: .1em;\n    margin: 0 0 12px;\n  }\n\n  .octo-hero h1,\n  .octo-section-heading h2 {\n    font-size: clamp(42px, 6vw, 82px);\n    line-height: .95;\n    margin: 0;\n    letter-spacing: -0.04em;\n  }\n\n  .octo-hero p,\n  .octo-card p,\n  .octo-step p,\n  .octo-troubleshooting p,\n  .octo-faq p {\n    color: rgba(255,255,255,.76);\n    font-size: 19px;\n    line-height: 1.55;\n  }\n\n  .octo-card {\n    display: grid;\n    grid-template-columns: .9fr 1.1fr;\n    gap: 36px;\n    align-items: center;\n    background: linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.025));\n    border: 1px solid rgba(255,255,255,.14);\n    border-radius: 22px;\n    padding: 34px;\n    margin-bottom: 28px;\n    box-shadow: 0 20px 60px rgba(0,0,0,.25);\n  }\n\n  .octo-card--main {\n    border-color: rgba(255,106,19,.5);\n  }\n\n  .octo-card h2 {\n    font-size: clamp(32px, 4vw, 58px);\n    line-height: 1;\n    margin: 0 0 18px;\n    letter-spacing: -0.035em;\n  }\n\n  .octo-card__image img {\n    width: 100%;\n    display: block;\n    border-radius: 18px;\n  }\n\n  .octo-steps {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 18px;\n    margin: 28px 0;\n  }\n\n  .octo-step,\n  .octo-troubleshooting div,\n  .octo-faq details {\n    background: rgba(255,255,255,.055);\n    border: 1px solid rgba(255,255,255,.13);\n    border-radius: 18px;\n    padding: 28px;\n  }\n\n  .octo-step span {\n    display: inline-grid;\n    place-items: center;\n    width: 42px;\n    height: 42px;\n    border-radius: 50%;\n    background: #FF6A13;\n    color: #05070a;\n    font-weight: 900;\n    font-size: 20px;\n    margin-bottom: 18px;\n  }\n\n  .octo-step h3,\n  .octo-troubleshooting h3 {\n    font-size: 28px;\n    margin: 0 0 10px;\n  }\n\n  .octo-section-heading {\n    margin-top: 70px;\n  }\n\n  .octo-troubleshooting {\n    display: grid;\n    grid-template-columns: repeat(2, 1fr);\n    gap: 18px;\n  }\n\n  .octo-faq {\n    display: grid;\n    gap: 12px;\n  }\n\n  .octo-faq details {\n    padding: 0;\n    overflow: hidden;\n  }\n\n  .octo-faq details[open] {\n    border-color: #FF6A13;\n    box-shadow: 0 0 0 1px rgba(255,106,19,.35);\n  }\n\n  .octo-faq summary {\n    cursor: pointer;\n    list-style: none;\n    padding: 24px 28px;\n    font-size: clamp(20px, 1.6vw, 26px);\n    font-weight: 850;\n  }\n\n  .octo-faq summary::-webkit-details-marker {\n    display: none;\n  }\n\n  .octo-faq p {\n    margin: 0;\n    padding: 0 28px 28px;\n    max-width: 1050px;\n  }\n\n  @media screen and (max-width: 900px) {\n    .octo-instructions {\n      padding: 54px 16px;\n    }\n\n    .octo-hero,\n    .octo-section-heading {\n      text-align: left;\n    }\n\n    .octo-card,\n    .octo-steps,\n    .octo-troubleshooting {\n      grid-template-columns: 1fr;\n    }\n\n    .octo-card {\n      padding: 22px;\n    }\n  }\n</style>",

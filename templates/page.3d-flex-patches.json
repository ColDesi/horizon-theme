    "octo_faq_XJgz7T": {
      "type": "octo-faq",
      "blocks": {
        "faq_hFhJdw": {
          "type": "faq",
          "settings": {
            "question": "What are 3D Flex Patches?",
            "answer": "<p>3D Flex patches combine vibrant full color printing with raised and recessed details to create a patch that looks and feels dimensional. Unlike traditional embroidered patches, 3D Flex lets you reproduce fine details, smooth gradients, and unlimited colors while adding sculpted depth for a premium appearance. Every patch is heat applied for fast, clean application to hats, jackets, bags, uniforms, and more.</p>"
          }
        },
        "faq_Lq7pcT": {
          "type": "faq",
          "settings": {
            "question": "What can I apply 3D Flex patches to?",
            "answer": "<p>3D Flex patches work great on hats, jackets, hoodies, backpacks, uniforms, tote bags, and many other heat-compatible fabrics.</p>"
          }
        },
        "faq_AHM4cb": {
          "type": "faq",
          "settings": {
            "question": "Can my patch include photographs or gradients?",
            "answer": "<p>Yes. Because 3D Flex uses full color printing, you can include photographs, gradients, shadows, and intricate artwork that would be difficult or impossible with embroidery.</p>"
          }
        },
        "faq_mB7Bdp": {
          "type": "faq",
          "settings": {
            "question": "Can I create any shape?",
            "answer": "<p>Absolutely. Choose from standard shapes like circles, shields, and hexagons, or upload a custom outline for a unique die-cut patch.</p>"
          }
        },
        "faq_TbfLyn": {
          "type": "faq",
          "settings": {
            "question": "Are 3D Flex patches durable?",
            "answer": "<p>Yes. 3D Flex patches are designed for everyday wear and hold up well through regular use and repeated washing when applied according to the recommended instructions.</p>"
          }
        },
        "faq_jpJQ9m": {
          "type": "faq",
          "settings": {
            "question": "How are 3D Flex patches different from embroidered patches?",
            "answer": "<p>Embroidery is limited by thread, which can make small details and color gradients difficult to reproduce. 3D Flex patches use full color printing with dimensional textures, allowing for sharper artwork, more colors, and raised effects that embroidery can't achieve.</p>"
          }
        },
        "faq_z37Ae8": {
          "type": "faq",
          "settings": {
            "question": "How do I apply my patch?",
            "answer": "<p>3d Flex Patches are heat applied using a heat press. Place the patch, cover it with parchment or a protective sheet, press using the recommended time, temperature, and pressure, then allow it to cool.</p>"
          }
        },
        "faq_tqAMnM": {
          "type": "faq",
          "settings": {
            "question": "Can I order different designs to reach volume pricing?",
            "answer": "<p>Yes. You can mix designs, shapes, materials, and finishes while still building toward volume discounts across your order.</p>"
          }
        },
        "faq_eDxMtH": {
          "type": "faq",
          "settings": {
            "question": "Can I see my design before ordering?",
            "answer": "<p>Yes. Our online designer lets you create, customize, and preview your patch before adding it to your cart.</p>"
          }
        },
        "faq_EW8GXF": {
          "type": "faq",
          "settings": {
            "question": "Can I order just one patch?",
            "answer": "<p>Yes. Whether you need one custom patch or thousands, there's no minimum order quantity.</p>"
          }
        },
        "faq_JqRQeH": {
          "type": "faq",
          "settings": {
            "question": "Do I need to sew them on?",
            "answer": "<p>No. 3D Flex patches are designed to be heat applied using a standard heat press. No sewing is required.</p>"
          }
        }
      },

    "custom_liquid_wFiMC7": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<section class=\"op-hero\">\n  <div class=\"op-hero__inner\">\n\n    <div class=\"op-copy\">\n      <div class=\"op-eyebrow\">CUSTOM</div>\n      <div class=\"op-title\">PATCHES</div>\n      <div class=\"op-line\"></div>\n\n      <div class=\"op-subtitle\">\n        Any Look. Any Feel.<br>\n        Limitless Possibilities.\n      </div>\n    </div>\n\n    <div class=\"op-center\">\n      <div class=\"op-logo\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0834/8562/2516/files/OctoPatches_Logo_3000_x_600_px.png?v=1783020054\" alt=\"OctoPatches\">\n      </div>\n\n      <div class=\"op-cta\">\n        {%- render 'design_button',\n          product: product,\n          variant: product.selected_or_first_available_variant -%}\n\n        {%- render 'sso_link',\n          label: 'Open saved patch designs',\n          next: '/my/designs'\n        -%}\n      </div>\n    </div>\n\n  </div>\n</section>\n\n<style>\n.op-hero {\n  position: relative;\n  width: 100%;\n  min-height: 675px;\n  overflow: hidden;\n  background-image: url('https://cdn.shopify.com/s/files/1/0834/8562/2516/files/OctoPatches_Website_Homepage_Image_2100x750_v.4.png?v=1783019673');\n  background-size: cover;\n  background-position: center top;\n  background-repeat: no-repeat;\n}\n\n.op-hero__inner {\n  position: relative;\n  width: 100%;\n  min-height: 675px;\n}\n\n.op-copy {\n  position: absolute;\n  left: clamp(28px, 4vw, 64px);\n  top: 58px;\n  z-index: 3;\n}\n\n.op-eyebrow,\n.op-title {\n  font-weight: 900;\n  text-transform: uppercase;\n  line-height: .88;\n  letter-spacing: -2px;\n  text-shadow: 0 4px 12px rgba(0,0,0,.65);\n}\n\n.op-eyebrow {\n  color: #ffffff;\n  font-size: clamp(34px, 4.1vw, 66px);\n}\n\n.op-title {\n  font-size: clamp(42px, 5vw, 78px);\n  background: linear-gradient(90deg, #7b3cff, #d84ca8, #ff8840, #56d8d8);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n}\n\n.op-line {\n  width: clamp(210px, 24vw, 360px);\n  height: 4px;\n  margin: 20px 0 26px;\n  background: linear-gradient(90deg, #7b3cff, #d84ca8, #ff8840, #56d8d8);\n}\n\n.op-subtitle {\n  color: #ffffff;\n  font-weight: 600;\n  font-size: clamp(20px, 1.9vw, 30px);\n  line-height: 1.2;\n  text-shadow: 0 3px 10px rgba(0,0,0,.75);\n}\n\n.op-center {\n  position: absolute;\n  left: 50%;\n  bottom: 34px;\n  transform: translateX(-50%);\n  z-index: 10;\n  width: min(90%, 620px);\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 18px;\n}\n\n.op-logo img {\n  width: clamp(360px, 32vw, 600px);\n  height: auto;\n  display: block;\n}\n\n.op-cta {\n  display: flex;\n  gap: 14px;\n  align-items: center;\n  justify-content: center;\n  flex-wrap: wrap;\n}\n\n/* Tablet */\n@media (max-width: 990px) {\n  .op-hero,\n  .op-hero__inner {\n    min-height: 600px;\n  }\n\n  .op-copy {\n    left: 24px;\n    top: 44px;\n  }\n\n  .op-center {\n    bottom: 28px;\n  }\n\n  .op-logo img {\n    width: 420px;\n  }\n}\n\n/* Mobile */\n@media (max-width: 749px) {\n  .op-hero,\n  .op-hero__inner {\n    min-height: 620px;\n    background-position: 58% top;\n  }\n\n  .op-copy {\n    left: 20px;\n    top: 34px;\n    max-width: 290px;\n  }\n\n  .op-eyebrow {\n    font-size: 38px;\n  }\n\n  .op-title {\n    font-size: 46px;\n  }\n\n  .op-line {\n    width: 220px;\n    margin: 14px 0 16px;\n  }\n\n  .op-subtitle {\n    font-size: 22px;\n  }\n\n  .op-center {\n    width: 92%;\n    bottom: 24px;\n  }\n\n  .op-logo img {\n    width: 310px;\n  }\n}\n</style>",

    "custom_liquid_prUH6C": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<section class=\"octo-compare\">\n  <div class=\"octo-compare__inner\">\n    <div class=\"octo-compare__header\">\n      <h2>Why OctoPatches?</h2>\n      <p>Traditional patches are fine. OctoPatches are built for more color, more texture, and way less hassle.</p>\n    </div>\n\n    <div class=\"octo-compare__grid\">\n      <div class=\"octo-compare__card octo-compare__card--traditional\">\n        <h3>Traditional Patches</h3>\n\n        <div class=\"octo-compare__row\">\n          <span>Limited materials</span>\n        </div>\n        <div class=\"octo-compare__row\">\n          <span>Often sewing required</span>\n        </div>\n        <div class=\"octo-compare__row\">\n          <span>Limited color detail</span>\n        </div>\n        <div class=\"octo-compare__row\">\n          <span>Setup fees and minimums</span>\n        </div>\n        <div class=\"octo-compare__row\">\n          <span>Expensive!</span>\n        </div>\n      </div>\n\n      <div class=\"octo-compare__card octo-compare__card--octo\">\n        <h3>OctoPatches</h3>\n\n        <div class=\"octo-compare__row\">\n          <span>Realistic faux textures like leather, camo, wood, and more</span>\n        </div>\n        <div class=\"octo-compare__row\">\n          <span>Heat apply in seconds (No Sewing needed!)</span>\n        </div>\n        <div class=\"octo-compare__row\">\n          <span>Full-color graphics with bold detail</span>\n        </div>\n        <div class=\"octo-compare__row\">\n          <span>No minimums. Order one or thousands.</span>\n        </div>\n        <div class=\"octo-compare__row\">\n          <span>Design online and preview before you buy</span>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<style>\n  .octo-compare {\n    background: #111315;\n    color: #ffffff;\n    padding: 70px 20px;\n  }\n\n  .octo-compare__inner {\n    max-width: 1180px;\n    margin: 0 auto;\n  }\n\n  .octo-compare__header {\n    text-align: center;\n    margin-bottom: 38px;\n  }\n\n  .octo-compare__header h2 {\n    margin: 0 0 12px;\n    font-size: clamp(34px, 5vw, 58px);\n    line-height: 1.05;\n    font-weight: 800;\n    color: #ffffff;\n  }\n\n  .octo-compare__header p {\n    margin: 0 auto;\n    max-width: 720px;\n    font-size: 18px;\n    line-height: 1.5;\n    color: #d7d7d7;\n  }\n\n  .octo-compare__grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 22px;\n  }\n\n  .octo-compare__card {\n    border: 1px solid rgba(255,255,255,.14);\n    border-radius: 18px;\n    padding: 28px;\n    background: #171a1d;\n  }\n\n  .octo-compare__card--octo {\n    border-color: #1683ff;\n    box-shadow: 0 0 0 1px rgba(22,131,255,.35), 0 20px 60px rgba(0,0,0,.3);\n  }\n\n  .octo-compare__card h3 {\n    margin: 0 0 22px;\n    font-size: 28px;\n    color: #ffffff;\n  }\n\n  .octo-compare__row {\n    padding: 16px 0;\n    border-top: 1px solid rgba(255,255,255,.12);\n    font-size: 17px;\n    line-height: 1.4;\n    color: #eeeeee;\n  }\n\n  .octo-compare__row:before {\n    content: \"•\";\n    color: #1683ff;\n    font-weight: 900;\n    margin-right: 10px;\n  }\n\n  .octo-compare__card--traditional .octo-compare__row:before {\n    color: #777;\n  }\n\n  @media screen and (max-width: 749px) {\n    .octo-compare {\n      padding: 48px 16px;\n    }\n\n    .octo-compare__grid {\n      grid-template-columns: 1fr;\n    }\n\n    .octo-compare__card {\n      padding: 22px;\n    }\n\n    .octo-compare__card h3 {\n      font-size: 24px;\n    }\n\n    .octo-compare__row {\n      font-size: 15px;\n    }\n  }\n</style>",
        "background_color": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },

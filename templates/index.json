            "custom_liquid": "<section class=\"op-hero\">\n  <div class=\"op-hero__content\">\n    <div class=\"op-eyebrow\">Custom</div>\n    <div class=\"op-title\">Patches</div>\n\n    <div class=\"op-line\"></div>\n\n    <p class=\"op-subtitle\">\n      Any Look. Any Feel.<br>\n      Limitless Possibilities.\n    </p>\n  </div>\n</section>\n\n<style>\n.op-hero {\n  position: relative;\n  width: 100%;\n  min-height: clamp(420px, 35vw, 675px);\n  background-image: url('https://cdn.shopify.com/s/files/1/0834/8562/2516/files/OctoPatches_Website_Homepage_Image_2100x750_v.3.png?v=1783019673');\n  background-size: cover;\n  background-position: center center;\n  background-repeat: no-repeat;\n  overflow: hidden;\n}\n\n.op-hero__content {\n  position: absolute;\n  left: clamp(24px, 5vw, 90px);\n  top: clamp(45px, 7vw, 95px);\n  z-index: 2;\n  color: #fff;\n  max-width: 600px;\n}\n\n.op-eyebrow,\n.op-title {\n  font-family: inherit;\n  font-weight: 900;\n  text-transform: uppercase;\n  line-height: .9;\n  letter-spacing: -2px;\n}\n\n.op-eyebrow {\n  font-size: clamp(48px, 7vw, 118px);\n  color: #f4f4f4;\n  text-shadow: 0 3px 8px rgba(0,0,0,.55);\n}\n\n.op-title {\n  font-size: clamp(58px, 8.2vw, 140px);\n  background: linear-gradient(90deg, #8b3cff, #ff3f8f, #ff8a00, #24d6d6);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n}\n\n.op-line {\n  width: min(100%, 540px);\n  height: 4px;\n  margin: clamp(16px, 2vw, 26px) 0 clamp(18px, 2.2vw, 30px);\n  background: linear-gradient(90deg, #8b3cff, #ff3f8f, #ff8a00, #24d6d6);\n}\n\n.op-subtitle {\n  font-size: clamp(26px, 3vw, 52px);\n  line-height: 1.15;\n  font-weight: 700;\n  margin: 0;\n  color: #f2f2f2;\n  text-shadow: 0 3px 8px rgba(0,0,0,.7);\n}\n\n@media screen and (max-width: 749px) {\n  .op-hero {\n    min-height: 520px;\n    background-position: 62% center;\n  }\n\n  .op-hero__content {\n    top: 38px;\n    left: 22px;\n    max-width: 330px;\n  }\n}\n</style>"

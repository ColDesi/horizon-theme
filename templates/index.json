    "octo_faq_qeK47g": {
      "type": "octo-faq",
      "blocks": {
        "faq_U4zPj7": {
          "type": "faq",
          "settings": {
            "question": "What are OctoPatches?",
            "answer": "<p>OctoPatches and 3D Flex are premium heat-applied patches that combine vibrant full-color printing with an easy online designer. Create your own custom designs and even utilize realistic textured materials like leather, canvas, camouflage, wood, brushed metal, and more.</p>"
          }
        },
        "faq_HDgjwi": {
          "type": "faq",
          "settings": {
            "question": "What is the difference between a Custom Patch and a 3D Flex Patch?",
            "answer": "<p>Both are premium, heat-applied, durable, and made for real-world use. The difference is what you are designing: the patch itself, or the artwork that becomes the patch. Learn more on our <a href=\"/pages/compare-patch-styles\" title=\"Compare Patch Styles\">comparison page.</a></p><p><strong>Custom Patch</strong> - Traditional patch look with your choice of material look, border and shape. </p><p><strong>3D Flex</strong> - Use art / logos to make patches and control design height with matte/gloss effects.</p>"
          }
        },
        "faq_78q79P": {
          "type": "faq",
          "settings": {
            "question": "Can I print a full color image on any of these materials?",
            "answer": "<p>Our unique process allows for creating your logo or art on faux materials. These can be  raised, sunken or textured. They also can be all black, all white or full color. The process revolutionizes patches.</p>"
          }
        },
        "faq_QKQNLt": {
          "type": "faq",
          "settings": {
            "question": "What can I apply them to?",
            "answer": "<p>OctoPatches adhere to most heat-safe materials including hats, cotton, polyester, performance fabrics, jackets, tote bags, backpacks, and more.</p>"
          }
        },
        "faq_9kBptt": {
          "type": "faq",
          "settings": {
            "question": "How do I apply my patch?",
            "answer": "<p>Simply apply your patch with a heat press using our recommended time, temperature, and pressure settings. No sewing required. 320degrees F for 15 seconds.<br/><br/></p>"
          }
        },
        "faq_UDQ7Qw": {
          "type": "faq",
          "settings": {
            "question": "Do you offer bulk discounts?",
            "answer": "<p>Yes. Check the product pricing page for volume discounts. The more you order, the more you save.</p>"
          }
        },
        "faq_weJcqr": {
          "type": "faq",
          "settings": {
            "question": "Can I order different designs to reach volume pricing?",
            "answer": "<p>Yes. You can mix and match different patch designs, sizes, and materials to qualify for volume discounts.</p>"
          }
        },
        "faq_7fD89B": {
          "type": "faq",
          "settings": {
            "question": "What materials are available?",
            "answer": "<p>Choose from a growing library of textures including:</p><ul><li>Leather</li><li>Canvas</li><li>Denim</li><li>Camo</li><li>Buffalo Plaid</li><li>Carbon Fiber</li><li>Wood</li><li>Brushed Aluminum</li><li>Pebbled Leather</li><li>Alligator</li><li>And many more.</li></ul>"
          }
        },
        "faq_Qk9QKt": {
          "type": "faq",
          "settings": {
            "question": "How do I get tax exempt?",
            "answer": "<p>Email your tax certificate to care@octopatches.com. Allow for 2-4 business days for this to be processed. OctoPatches does NOT refund taxes paid. If you pay taxes, and are exempt, contact your tax advisor. </p>"
          }
        },
        "faq_x4xVay": {
          "type": "faq",
          "settings": {
            "question": "Can I make any shape?",
            "answer": "<p>Yes! Choose from many popular shapes or upload your own.</p>"
          }
        },
        "faq_cWMegc": {
          "type": "faq",
          "settings": {
            "question": "Can I upload my own logo?",
            "answer": "<p>Absolutely. Upload your logo, artwork, or design directly into our online designer.</p>"
          }
        },
        "faq_dAYmbk": {
          "type": "faq",
          "settings": {
            "question": "Is there a minimum order?",
            "answer": "<p>No. Order one patch or thousands.</p>"
          }
        },
        "faq_knRPKz": {
          "type": "faq",
          "settings": {
            "question": "Do I need to sew them on?",
            "answer": "<p>No. They are designed to be heat applied.</p>"
          }
        },
        "faq_z766Ke": {
          "type": "faq",
          "settings": {
            "question": "Are they washable?",
            "answer": "<p>Yes. When applied correctly, OctoPatches are made to withstand regular wear and washing.</p>"
          }
        },
        "faq_T9x8fA": {
          "type": "faq",
          "settings": {
            "question": "Are these real materials like leather or wood?",
            "answer": "<p>OctoPatch proprietary technology creates a faux look for all of the materials. Users say that these look so good, they cannot believe its not real.</p>"
          }
        },
        "faq_QRyMJH": {
          "type": "faq",
          "settings": {
            "question": "Why the Octopus?",
            "answer": "<p><strong>The octopus is nature's master of adaptability.</strong> It can change color, texture, and shape to fit almost any environment. OctoPatches are built with that same philosophy. Instead of being limited to one material or one style, you can create patches in countless combinations of shapes, finishes, textures, and materials, all in a single order.</p>"
          }
        },
        "faq_kmVWeD": {
          "type": "faq",
          "settings": {
            "question": "How do I place an international order (outside the USA) ?",
            "answer": "<p>Email care@octopatches.com to place your order. This will be automated in the online store soon, we are working on making the international experience as best as possible. </p>"
          }
        }
      },

            "custom_liquid_YiQi7B": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "{% if product.variants.size > 0 %}\n<div class=\"patch-volume-pricing\" id=\"patch-volume-pricing\">\n  <div class=\"pvp-header\">\n    <h3>Volume Patch Discounts</h3>\n    <p>\n      Mix and match any patch sizes to unlock volume pricing. Below chart assumes all patches are the same size, but you can mix and match. Discounts are based on your total patch quantity in cart.\n    </p>\n    <p class=\"pvp-example\">\n      Example: 10 Small + 20 XL = 30 total patches, so you qualify for the 25+ discount tier.\n    </p>\n  </div>\n\n  <div class=\"pvp-size-buttons\" role=\"tablist\">\n    {% for variant in product.variants %}\n      <button\n        type=\"button\"\n        class=\"pvp-size-button {% if forloop.first %}active{% endif %}\"\n        data-variant-id=\"{{ variant.id }}\"\n        data-price=\"{{ variant.price | divided_by: 100.0 }}\"\n        data-title=\"{{ variant.title | escape }}\"\n      >\n        {{ variant.title | split: ':' | first }}\n      </button>\n    {% endfor %}\n  </div>\n\n  <div class=\"pvp-selected-size\">\n    Viewing discounts for: <strong id=\"pvp-current-size\">{{ product.variants.first.title }}</strong>\n  </div>\n\n  <table class=\"pvp-table\">\n    <thead>\n      <tr>\n        <th>Total Qty</th>\n        <th>Regular</th>\n        <th>Discount</th>\n        <th>You Pay</th>\n        <th>Save Each</th>\n      </tr>\n    </thead>\n    <tbody id=\"pvp-table-body\"></tbody>\n  </table>\n\n  <p class=\"pvp-note\">\n    Final pricing is applied automatically in cart and checkout.\n  </p>\n</div>\n\n<style>\n  .patch-volume-pricing {\n    border: 1px solid #d8d8d8;\n    border-radius: 10px;\n    padding: 18px;\n    margin-top: 18px;\n    background: #fff;\n    font-size: 14px;\n  }\n\n  .patch-volume-pricing h3 {\n    margin: 0 0 8px;\n    font-size: 22px;\n    line-height: 1.1;\n  }\n\n  .patch-volume-pricing p {\n    margin: 0 0 10px;\n    line-height: 1.4;\n  }\n\n  .pvp-example {\n    font-size: 13px;\n    color: #444;\n  }\n\n  .pvp-size-buttons {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 8px;\n    margin: 14px 0;\n  }\n\n  .pvp-size-button {\n    border: 1px solid #111;\n    background: #fff;\n    color: #111;\n    border-radius: 999px;\n    padding: 8px 12px;\n    cursor: pointer;\n    font-size: 13px;\n  }\n\n  .pvp-size-button.active {\n    background: #111;\n    color: #fff;\n  }\n\n  .pvp-selected-size {\n    margin-bottom: 10px;\n    font-size: 13px;\n  }\n\n  .pvp-table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 13px;\n  }\n\n  .pvp-table th,\n  .pvp-table td {\n    border-bottom: 1px solid #e5e5e5;\n    padding: 9px 6px;\n    text-align: right;\n  }\n\n  .pvp-table th:first-child,\n  .pvp-table td:first-child {\n    text-align: left;\n  }\n\n  .pvp-table th {\n    font-weight: 700;\n    color: #111;\n  }\n\n  .pvp-note {\n    margin-top: 12px !important;\n    font-size: 12px;\n    color: #555;\n  }\n\n  @media screen and (max-width: 600px) {\n    .patch-volume-pricing {\n      padding: 14px;\n    }\n\n    .pvp-table {\n      font-size: 12px;\n    }\n\n    .pvp-table th,\n    .pvp-table td {\n      padding: 8px 4px;\n    }\n  }\n</style>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function () {\n    const tiers = [\n      { qty: 10, discount: 50 },\n      { qty: 25, discount: 64 },\n      { qty: 50, discount: 68 },\n      { qty: 100, discount: 73 },\n      { qty: 500, discount: 78 },\n      { qty: 1000, discount: 81 },\n      { qty: 5000, discount: 84 }\n    ];\n\n    const buttons = document.querySelectorAll('.pvp-size-button');\n    const tableBody = document.getElementById('pvp-table-body');\n    const currentSize = document.getElementById('pvp-current-size');\n\n    function money(value) {\n      return '$' + Number(value).toFixed(2);\n    }\n\n    function renderTable(button) {\n      const regularPrice = parseFloat(button.dataset.price);\n      const title = button.dataset.title;\n\n      currentSize.textContent = title;\n      tableBody.innerHTML = '';\n\n      tiers.forEach(function (tier) {\n        const discountedPrice = regularPrice * (1 - tier.discount / 100);\n        const savings = regularPrice - discountedPrice;\n\n        const row = document.createElement('tr');\n\n        row.innerHTML = `\n          <td>${tier.qty}+</td>\n          <td>${money(regularPrice)}</td>\n          <td>${tier.discount}% off</td>\n          <td><strong>${money(discountedPrice)}</strong></td>\n          <td>${money(savings)}</td>\n        `;\n\n        tableBody.appendChild(row);\n      });\n    }\n\n    buttons.forEach(function (button) {\n      button.addEventListener('click', function () {\n        buttons.forEach(function (btn) {\n          btn.classList.remove('active');\n        });\n\n        button.classList.add('active');\n        renderTable(button);\n      });\n    });\n\n    if (buttons.length > 0) {\n      renderTable(buttons[0]);\n    }\n  });\n</script>\n{% endif %}"

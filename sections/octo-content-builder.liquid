<section
  class="octo-content-builder"
  style="
    --octo-bg: {{ section.settings.background_color }};
    --octo-text: {{ section.settings.text_color }};
    --octo-width: {{ section.settings.content_width }}px;
    --octo-padding-top: {{ section.settings.padding_top }}px;
    --octo-padding-bottom: {{ section.settings.padding_bottom }}px;
    --octo-align: {{ section.settings.text_alignment }};
  "
>
  <div class="octo-content-builder__inner">
    {% for block in section.blocks %}
      {% case block.type %}

        {% when 'heading' %}
          <{{ block.settings.heading_tag }}
            class="octo-content-builder__heading"
            style="
              font-size: {{ block.settings.font_size }}px;
              color: {{ block.settings.color }};
              text-align: {{ block.settings.alignment }};
            "
            {{ block.shopify_attributes }}
          >
            {{ block.settings.text }}
          </{{ block.settings.heading_tag }}>

        {% when 'paragraph' %}
          <div
            class="octo-content-builder__text"
            style="
              font-size: {{ block.settings.font_size }}px;
              color: {{ block.settings.color }};
              text-align: {{ block.settings.alignment }};
            "
            {{ block.shopify_attributes }}
          >
            {{ block.settings.text }}
          </div>

        {% when 'image' %}
  {% if block.settings.image != blank %}

    {% if block.settings.full_width %}
      <div
        class="octo-content-builder__image-full"
        {{ block.shopify_attributes }}
      >
        <img
          src="{{ block.settings.image | image_url: width: 2400 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          style="border-radius: {{ block.settings.border_radius }}px;"
        >
      </div>

    {% else %}
      <div
        class="octo-content-builder__image-wrap octo-content-builder__image-wrap--{{ block.settings.alignment }}"
        {{ block.shopify_attributes }}
      >
        <img
          src="{{ block.settings.image | image_url: width: 1600 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          style="
            max-width: {{ block.settings.image_width }}px;
            border-radius: {{ block.settings.border_radius }}px;
          "
        >
      </div>
    {% endif %}

  {% endif %}

        {% when 'button' %}
          {% if block.settings.button_text != blank %}
            <div
              class="octo-content-builder__button-wrap octo-content-builder__button-wrap--{{ block.settings.alignment }}"
              {{ block.shopify_attributes }}
            >
              <a
                href="{{ block.settings.button_link | default: '#' }}"
                class="octo-content-builder__button octo-content-builder__button--{{ block.settings.button_style }}"
                {% if block.settings.open_new_tab %}
                  target="_blank" rel="noopener noreferrer"
                {% endif %}
              >
                {{ block.settings.button_text }}
              </a>
            </div>
          {% endif %}

        {% when 'spacer' %}
          <div style="height: {{ block.settings.height }}px;" {{ block.shopify_attributes }}></div>

      {% endcase %}
    {% endfor %}
  </div>
</section>

<style>
  .octo-content-builder {
    background: var(--octo-bg);
    color: var(--octo-text);
    padding-top: var(--octo-padding-top);
    padding-bottom: var(--octo-padding-bottom);
  }

  .octo-content-builder__inner {
    max-width: var(--octo-width);
    margin: 0 auto;
    padding: 0 20px;
    text-align: var(--octo-align);
  }

  .octo-content-builder__heading {
    margin: 0 0 16px;
    line-height: 1.05;
    font-weight: 800;
  }

  .octo-content-builder__text {
    margin: 0 0 18px;
    line-height: 1.55;
  }

  .octo-content-builder__text p {
    margin-top: 0;
  }

  .octo-content-builder__image-wrap {
    margin: 24px 0;
    display: flex;
  }

  .octo-content-builder__image-wrap--left {
    justify-content: flex-start;
  }

  .octo-content-builder__image-wrap--center {
    justify-content: center;
  }

  .octo-content-builder__image-wrap--right {
    justify-content: flex-end;
  }

  .octo-content-builder__image-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }

  .octo-content-builder__button-wrap {
    display: flex;
    margin-top: 22px;
  }

  .octo-content-builder__button-wrap--left {
    justify-content: flex-start;
  }

  .octo-content-builder__button-wrap--center {
    justify-content: center;
  }

  .octo-content-builder__button-wrap--right {
    justify-content: flex-end;
  }

  .octo-content-builder__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 28px;
    border-radius: 999px;
    font-weight: 800;
    text-decoration: none;
    line-height: 1;
    transition: all 0.2s ease;
    border: 2px solid transparent;
  }

  .octo-content-builder__button--primary {
    background: #f26a21;
    color: #ffffff;
    border-color: #f26a21;
  }

  .octo-content-builder__button--primary:hover {
    background: #ffffff;
    color: #f26a21;
    border-color: #ffffff;
    transform: translateY(-2px);
  }

  .octo-content-builder__button--secondary {
    background: #ffffff;
    color: #111111;
    border-color: #ffffff;
  }

  .octo-content-builder__button--secondary:hover {
    background: #f26a21;
    color: #ffffff;
    border-color: #f26a21;
    transform: translateY(-2px);
  }

  .octo-content-builder__button--outline {
    background: transparent;
    color: #ffffff;
    border-color: #ffffff;
  }

  .octo-content-builder__button--outline:hover {
    background: #ffffff;
    color: #111111;
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .octo-content-builder__heading {
      font-size: clamp(28px, 8vw, 42px) !important;
    }

    .octo-content-builder__text {
      font-size: 16px !important;
    }

    .octo-content-builder__button {
      width: 100%;
    }
  }




.octo-content-builder__image-full {
  width: 100vw;
  margin-left: calc(50% - 50vw);
  margin-top: 24px;
  margin-bottom: 24px;
}

.octo-content-builder__image-full img {
  display: block;
  width: 100%;
  height: auto;
}



</style>


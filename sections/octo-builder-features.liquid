<section class="octo-features">
  <div class="octo-features-wrap">
    <div class="octo-features-head">
      <p>{{ section.settings.octo_eyebrow }}</p>
      <h2>{{ section.settings.octo_heading }}</h2>
      <div>{{ section.settings.octo_subheading }}</div>
    </div>

    <div class="octo-feature-grid">
      {% for block in section.blocks %}
        <div class="octo-feature-card" {{ block.shopify_attributes }}>
          {% if block.settings.octo_image != blank %}
            <img src="{{ block.settings.octo_image | image_url: width: 700 }}" alt="{{ block.settings.octo_title | escape }}" loading="lazy">
          {% else %}
            <div class="octo-feature-placeholder">Add image</div>
          {% endif %}

          <div class="octo-feature-copy">
            <span>0{{ forloop.index }}</span>
            <h3>{{ block.settings.octo_title }}</h3>
            <p>{{ block.settings.octo_text }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .octo-features {
    background: #050505;
    color: #fff;
    padding: 24px 20px 96px;
  }

  .octo-features-wrap {
    max-width: 1320px;
    margin: 0 auto;
  }

  .octo-features-head {
    text-align: center;
    max-width: 780px;
    margin: 0 auto 42px;
  }

  .octo-features-head p {
    color: #c9a7ff;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
    margin: 0 0 14px;
  }

  .octo-features-head h2 {
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1;
    margin: 0 0 14px;
    letter-spacing: -0.035em;
  }

  .octo-features-head div {
    color: rgba(255,255,255,.68);
    font-size: 17px;
    line-height: 1.5;
  }

  .octo-feature-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .octo-feature-card {
    background: linear-gradient(180deg, rgba(255,255,255,.075), rgba(255,255,255,.035));
    border: 1px solid rgba(255,255,255,.13);
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 24px 70px rgba(0,0,0,.35);
  }

  .octo-feature-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    border-bottom: 1px solid rgba(255,255,255,.1);
  }

  .octo-feature-placeholder {
    aspect-ratio: 4 / 3;
    display: grid;
    place-items: center;
    background: rgba(255,255,255,.05);
    color: rgba(255,255,255,.45);
    border-bottom: 1px solid rgba(255,255,255,.1);
  }

  .octo-feature-copy {
    padding: 20px;
  }

  .octo-feature-copy span {
    color: #ff8a35;
    font-weight: 900;
    font-size: 13px;
  }

  .octo-feature-copy h3 {
    margin: 8px 0 8px;
    font-size: 22px;
    line-height: 1.1;
  }

  .octo-feature-copy p {
    margin: 0;
    color: rgba(255,255,255,.66);
    font-size: 14px;
    line-height: 1.45;
  }

  @media screen and (max-width: 1000px) {
    .octo-feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 600px) {
    .octo-features {
      padding: 12px 16px 64px;
    }

    .octo-feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Octo Builder Features",
  "settings": [
    {
      "type": "text",
      "id": "octo_eyebrow",
      "label": "Eyebrow",
      "default": "Inside the Builder"
    },
    {
      "type": "text",
      "id": "octo_heading",
      "label": "Heading",
      "default": "Build Your Patch in Minutes"
    },
    {
      "type": "textarea",
      "id": "octo_subheading",
      "label": "Subheading",
      "default": "Choose your material, pick a shape, upload artwork, and preview your patch before you order."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "octo_image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "octo_title",
          "label": "Title",
          "default": "Choose Material"
        },
        {
          "type": "textarea",
          "id": "octo_text",
          "label": "Text",
          "default": "Pick from premium textures, colors, and specialty finishes."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Octo Builder Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "octo_title": "Choose Material",
            "octo_text": "Pick from leather, canvas, camo, wood, carbon fiber, and more."
          }
        },
        {
          "type": "feature",
          "settings": {
            "octo_title": "Pick a Shape",
            "octo_text": "Select from popular shapes or build a custom patch layout."
          }
        },
        {
          "type": "feature",
          "settings": {
            "octo_title": "Upload Artwork",
            "octo_text": "Add your logo, graphics, text, or custom design."
          }
        },
        {
          "type": "feature",
          "settings": {
            "octo_title": "Preview Live",
            "octo_text": "See your patch before you order, because guessing is for carnival games."
          }
        }
      ]
    }
  ]
}
{% endschema %}
<section
  class="octo-hero"
  style="
    --desktop-height: {{ section.settings.desktop_height }}px;
    --mobile-height: {{ section.settings.mobile_height }}px;
    --logo-width: {{ section.settings.logo_width }}px;
    --mobile-logo-width: {{ section.settings.mobile_logo_width }}px;
  "
>
  <div class="octo-hero__bg">
    {% if section.settings.bg_image != blank %}
      <picture>
        {% if section.settings.mobile_image != blank %}
          <source
            media="(max-width: 749px)"
            srcset="{{ section.settings.mobile_image | image_url: width: 1000 }}">
        {% endif %}

        <img
          class="octo-hero__image"
          src="{{ section.settings.bg_image | image_url: width: 2400 }}"
          alt="OctoPatches hero background"
          loading="eager">
      </picture>
    {% endif %}
  </div>

  <div class="octo-hero__content">
    <div class="octo-hero__text">
      <div class="octo-hero__eyebrow">{{ section.settings.eyebrow }}</div>
      <div class="octo-hero__title">{{ section.settings.title }}</div>
      <div class="octo-hero__line"></div>
      <div class="octo-hero__subtitle">{{ section.settings.subtitle | newline_to_br }}</div>
    </div>

    <div class="octo-hero__bottom">
      {% if section.settings.logo != blank %}
        <img
          class="octo-hero__logo"
          src="{{ section.settings.logo | image_url: width: 1400 }}"
          alt="{{ section.settings.logo_alt | escape }}"
        >
      {% endif %}

      <div class="octo-hero__cta">
  {% render 'patchmaker_button',
  logged_out_text: 'Start Designing → ',
  logged_in_text: 'Start Designing →',
  next: '/my/designs'
%}
</div>
    </div>
  </div>
</section>

<style>
.octo-hero {
  position: relative;
  width: 100%;
  min-height: var(--desktop-height);
  overflow: hidden;
  background: #050510;
}

.octo-hero__bg,
.octo-hero__bg picture,
.octo-hero__image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.octo-hero__image {
  object-fit: cover;
  object-position: center top;
}

.octo-hero__content {
  position: relative;
  z-index: 2;
  min-height: var(--desktop-height);
}

.octo-hero__text {
  position: absolute;
  left: clamp(28px, 4vw, 64px);
  top: 58px;
  max-width: 430px;
}

.octo-hero__eyebrow,
.octo-hero__title {
  font-weight: 900;
  text-transform: uppercase;
  line-height: .88;
  letter-spacing: -2px;
  text-shadow: 0 4px 14px rgba(0,0,0,.75);
}

.octo-hero__eyebrow {
  color: #fff;
  font-size: clamp(34px, 4vw, 66px);
}

.octo-hero__title {
  font-size: clamp(42px, 5vw, 78px);
  background: linear-gradient(
    180deg,
    #FFA14A 0%,
    #FF7E29 40%,
    #FF6A13 70%,
    #D94E00 100%
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: none;
}

.octo-hero__line {
  width: clamp(200px, 24vw, 350px);
  height: 4px;
  margin: 18px 0 22px;
  background: linear-gradient(90deg, #7b3cff, #d84ca8, #ff8840, #56d8d8);
}

.octo-hero__subtitle {
  color: #fff;
  font-weight: 600;
  font-size: clamp(20px, 1.8vw, 30px);
  line-height: 1.2;
  text-shadow: 0 3px 10px rgba(0,0,0,.8);
}

.octo-hero__bottom {
  position: absolute;
  left: 50%;
  bottom: 32px;
  transform: translateX(-50%);
  width: min(92%, 680px);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30px;
}

.octo-hero__logo {
  width: min(var(--logo-width), 90vw);
  height: auto;
  display: block;
}

.octo-hero__cta {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}

@media screen and (max-width: 749px) {
  .octo-hero {
    min-height: var(--mobile-height);
  }

  .octo-hero__content {
    min-height: var(--mobile-height);
  }

  .octo-hero__image {
    object-position: center top;
  }

  .octo-hero__text {
    left: 20px;
    top: 32px;
    max-width: 290px;
  }

  .octo-hero__eyebrow {
    font-size: 38px;
  }

  .octo-hero__title {
    font-size: 46px;
  }

  .octo-hero__line {
    width: 220px;
    margin: 14px 0 16px;
  }

  .octo-hero__subtitle {
    font-size: 22px;
  }

  .octo-hero__bottom {
    bottom: 24px;
    gap: 14px;
  }

  .octo-hero__logo {
    width: min(var(--mobile-logo-width), 88vw);
  }

  .octo-hero__cta {
    flex-direction: column;
    gap: 10px;
  }
}



/* Patchmaker button styling */

/* Hero Patchmaker Button */

.octo-hero .patchmaker-button-wrap {
  margin: 0;
}

.octo-hero .patchmaker-button {
  display: inline-flex !important;
  align-items: center;
  justify-content: center;

  min-width: 320px;
  min-height: 64px;

  padding: 20px 42px !important;

  border-radius: 999px !important;

  background: linear-gradient(180deg,#FF8B39 0%,#FF6A13 100%) !important;

  color: #fff !important;
  font-size: 20px;
  font-weight: 900;
  letter-spacing: .02em;
  text-decoration: none !important;

  border: 1px solid rgba(255,255,255,.15) !important;

  box-shadow:
    0 10px 30px rgba(255,106,19,.35),
    inset 0 1px 0 rgba(255,255,255,.25);

  transition: all .22s ease;
}

.octo-hero .patchmaker-button:hover {
  transform: translateY(-3px) scale(1.02);

  box-shadow:
    0 18px 42px rgba(255,106,19,.45),
    inset 0 1px 0 rgba(255,255,255,.35);
}

.octo-hero .patchmaker-button:active {
  transform: translateY(0);
}


</style>

{% schema %}
{
  "name": "OctoPatches Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Desktop background image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile background image"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "OctoPatches logo"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo alt text",
      "default": "OctoPatches"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Top headline",
      "default": "Custom"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main headline",
      "default": "Patches"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Any Look. Any Feel.\nLimitless Possibilities."
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop hero height",
      "min": 500,
      "max": 850,
      "step": 25,
      "default": 675
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile hero height",
      "min": 550,
      "max": 950,
      "step": 25,
      "default": 750
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Desktop logo width",
      "min": 300,
      "max": 850,
      "step": 25,
      "default": 575
    },
    {
      "type": "range",
      "id": "mobile_logo_width",
      "label": "Mobile logo width",
      "min": 220,
      "max": 500,
      "step": 20,
      "default": 320
    }
  ],
  "presets": [
    {
      "name": "OctoPatches Hero"
    }
  ]
}
{% endschema %}
<section class="octo-gallery">
  <div class="octo-gallery-wrap">
    <div class="octo-gallery-head">
      <p>{{ section.settings.octo_eyebrow }}</p>
      <h2>{{ section.settings.octo_heading }}</h2>
      <div>{{ section.settings.octo_subheading }}</div>
    </div>

    <div class="octo-gallery-grid">
      {% for block in section.blocks %}
        <div class="octo-gallery-card" {{ block.shopify_attributes }}>
          {% if block.settings.octo_image != blank %}
            <img src="{{ block.settings.octo_image | image_url: width: 900 }}" alt="{{ block.settings.octo_title | escape }}" loading="lazy">
          {% else %}
            <div class="octo-gallery-placeholder">Add image</div>
          {% endif %}

          <div class="octo-gallery-copy">
            <h3>{{ block.settings.octo_title }}</h3>
            <p>{{ block.settings.octo_text }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .octo-gallery {
    background: #050505;
    color: #fff;
    padding: 24px 20px 96px;
  }

  .octo-gallery-wrap {
    max-width: 1320px;
    margin: 0 auto;
  }

  .octo-gallery-head {
    text-align: center;
    max-width: 780px;
    margin: 0 auto 42px;
  }

  .octo-gallery-head p {
    color: #c9a7ff;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
    margin: 0 0 14px;
  }

  .octo-gallery-head h2 {
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1;
    margin: 0 0 14px;
    letter-spacing: -0.035em;
  }

  .octo-gallery-head div {
    color: rgba(255,255,255,.68);
    font-size: 17px;
    line-height: 1.5;
  }

  .octo-gallery-grid {
    display: grid;
    grid-template-columns: 1.2fr .8fr;
    gap: 20px;
  }

  .octo-gallery-card {
    position: relative;
    min-height: 360px;
    overflow: hidden;
    border-radius: 26px;
    border: 1px solid rgba(255,255,255,.13);
    background: rgba(255,255,255,.04);
    box-shadow: 0 24px 70px rgba(0,0,0,.35);
  }

  .octo-gallery-card:first-child {
    grid-row: span 2;
    min-height: 740px;
  }

  .octo-gallery-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .octo-gallery-card:after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 35%, rgba(0,0,0,.82) 100%);
    pointer-events: none;
  }

  .octo-gallery-copy {
    position: absolute;
    left: 24px;
    right: 24px;
    bottom: 24px;
    z-index: 2;
  }

  .octo-gallery-copy h3 {
    margin: 0 0 8px;
    font-size: 28px;
    line-height: 1.05;
  }

  .octo-gallery-copy p {
    margin: 0;
    color: rgba(255,255,255,.74);
    font-size: 15px;
    line-height: 1.45;
  }

  .octo-gallery-placeholder {
    height: 100%;
    min-height: 360px;
    display: grid;
    place-items: center;
    color: rgba(255,255,255,.45);
  }

  @media screen and (max-width: 900px) {
    .octo-gallery {
      padding: 12px 16px 64px;
    }

    .octo-gallery-grid {
      grid-template-columns: 1fr;
    }

    .octo-gallery-card,
    .octo-gallery-card:first-child {
      min-height: 420px;
      grid-row: auto;
    }
  }
</style>

{% schema %}
{
  "name": "Octo Product Gallery",
  "settings": [
    {
      "type": "text",
      "id": "octo_eyebrow",
      "label": "Eyebrow",
      "default": "Patch Inspiration"
    },
    {
      "type": "text",
      "id": "octo_heading",
      "label": "Heading",
      "default": "Make It Look Like Yours"
    },
    {
      "type": "textarea",
      "id": "octo_subheading",
      "label": "Subheading",
      "default": "From hats and jackets to bags and uniforms, OctoPatches are built for real products and real brands."
    }
  ],
  "blocks": [
    {
      "type": "gallery_item",
      "name": "Gallery image",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "octo_image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "octo_title",
          "label": "Title",
          "default": "Custom Hat Patch"
        },
        {
          "type": "textarea",
          "id": "octo_text",
          "label": "Text",
          "default": "Premium custom patch applied to a finished product."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Octo Product Gallery",
      "blocks": [
        {
          "type": "gallery_item",
          "settings": {
            "octo_title": "Hats & Caps",
            "octo_text": "Perfect for brands, teams, events, and outdoor gear."
          }
        },
        {
          "type": "gallery_item",
          "settings": {
            "octo_title": "Jackets & Apparel",
            "octo_text": "Add a premium custom look to wearable products."
          }
        },
        {
          "type": "gallery_item",
          "settings": {
            "octo_title": "Bags & Accessories",
            "octo_text": "Create retail-ready details for merch, uniforms, and gifts."
          }
        }
      ]
    }
  ]
}
{% endschema %}
    {
      "type": "text",
      "id": "octo_heading",
      "label": "Headline",
      "default": "Build Custom Patches or 3D Flex Online"
    },
    {
      "type": "textarea",
      "id": "octo_subheading",
      "label": "Subheadline",
      "default": "Choose the builder that fits your design. Both styles use the same pricing, volume discounts, and heat application process."
    },
    {
      "type": "text",
      "id": "octo_price_text",
      "label": "Price text",
      "default": "As Low As $1.44 per patch"
    },
    {
      "type": "text",
      "id": "octo_note",
      "label": "Small note",
      "default": "Same pricing • Same heat application • Mix any patches for volume discounts."
    },
    {
      "type": "text",
      "id": "custom_patch_heading",

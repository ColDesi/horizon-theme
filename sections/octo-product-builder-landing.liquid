      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "feature_text",
          "label": "Feature text",
          "default": "Your artwork is the patch"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Octo Builder Hero",
      "blocks": [
        {
          "type": "custom_patch_feature",
          "settings": { "feature_text": "50+ faux material options" }
        },
        {
          "type": "custom_patch_feature",
          "settings": { "feature_text": "Choose the shape & border" }
        },
        {
          "type": "custom_patch_feature",
          "settings": { "feature_text": "Add your artwork" }
        },
        {
          "type": "custom_patch_feature",
          "settings": { "feature_text": "Classic premium patch look" }
        },
        {
          "type": "flex_feature",
          "settings": { "feature_text": "Your artwork is the patch" }
        },
        {
          "type": "flex_feature",
          "settings": { "feature_text": "Control raised and flat details" }
        },
        {
          "type": "flex_feature",
          "settings": { "feature_text": "Add matte and gloss effects" }
        },
        {
          "type": "flex_feature",
          "settings": { "feature_text": "Modern sculpted look" }
        }
      ]
    }
  ]
}
{% endschema %}

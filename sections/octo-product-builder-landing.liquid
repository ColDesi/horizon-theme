<section class="octo-builder-hero">
  <div class="octo-wrap">
    <div class="octo-hero">
      <div class="octo-hero-media">
        {% if section.settings.octo_hero_image != blank %}
          <img
            src="{{ section.settings.octo_hero_image | image_url: width: 1400 }}"
            alt="{{ section.settings.octo_heading | escape }}"
            loading="lazy"
          >
        {% else %}
          <div class="octo-placeholder">Add main hero image</div>
        {% endif %}

        {% if section.settings.octo_builder_image != blank %}
          <div class="octo-float">
            <img
              src="{{ section.settings.octo_builder_image | image_url: width: 800 }}"
              alt="Custom Patches and 3D Flex builder preview"
              loading="lazy"
            >
          </div>
        {% endif %}
      </div>

      <div class="octo-hero-copy">
        {% if section.settings.octo_eyebrow != blank %}
          <div class="octo-eyebrow">{{ section.settings.octo_eyebrow }}</div>
        {% endif %}

        <h1>{{ section.settings.octo_heading }}</h1>
        <p>{{ section.settings.octo_subheading }}</p>

        <div class="octo-style-features">
          <div class="octo-style-column">
            <h3>{{ section.settings.custom_patch_heading }}</h3>

            <div class="octo-style-list">
              {% for block in section.blocks %}
                {% if block.type == 'custom_patch_feature' %}
                  <div class="octo-style-point" {{ block.shopify_attributes }}>
                    <span>✓</span>
                    <div>{{ block.settings.feature_text }}</div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>

          <div class="octo-style-column">
            <h3>{{ section.settings.flex_heading }}</h3>

            <div class="octo-style-list">
              {% for block in section.blocks %}
                {% if block.type == 'flex_feature' %}
                  <div class="octo-style-point" {{ block.shopify_attributes }}>
                    <span>✓</span>
                    <div>{{ block.settings.feature_text }}</div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>

        {% if section.settings.octo_price_text != blank %}
          <div class="octo-price">{{ section.settings.octo_price_text }}</div>
        {% endif %}

        {% if section.settings.octo_note != blank %}
          <div class="octo-note">{{ section.settings.octo_note }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .octo-builder-hero {
    background: #050505;
    color: #fff;
    padding: 72px 20px 56px;
  }

  .octo-builder-hero .octo-wrap {
    max-width: 1320px;
    margin: 0 auto;
  }

  .octo-builder-hero .octo-hero {
    display: grid;
    grid-template-columns: 1.15fr .85fr;
    gap: 48px;
    align-items: center;
  }

  .octo-builder-hero .octo-hero-media {
    position: relative;
  }

  .octo-builder-hero .octo-hero-media > img {
    width: 100%;
    display: block;
    border-radius: 28px;
    border: 1px solid rgba(255,255,255,.12);
    box-shadow: 0 28px 80px rgba(0,0,0,.55);
  }

  .octo-builder-hero .octo-float {
    position: absolute;
    right: -28px;
    bottom: -28px;
    width: 48%;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.16);
    box-shadow: 0 24px 60px rgba(0,0,0,.65);
    background: #111;
  }

  .octo-builder-hero .octo-float img {
    width: 100%;
    display: block;
  }

  .octo-builder-hero .octo-placeholder {
    min-height: 460px;
    border-radius: 28px;
    border: 1px dashed rgba(255,255,255,.25);
    display: grid;
    place-items: center;
    color: rgba(255,255,255,.6);
    background: #111;
  }

  .octo-builder-hero .octo-eyebrow {
    color: #c9a7ff;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
    font-size: 13px;
    margin-bottom: 18px;
  }

  .octo-builder-hero .octo-hero-copy h1 {
    font-size: clamp(42px, 5vw, 72px);
    line-height: .95;
    margin: 0 0 22px;
    letter-spacing: -.04em;
  }

  .octo-builder-hero .octo-hero-copy > p {
    color: rgba(255,255,255,.78);
    font-size: 18px;
    line-height: 1.55;
    max-width: 560px;
    margin: 0 0 24px;
  }

  .octo-builder-hero .octo-style-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin: 28px 0;
  }

  .octo-builder-hero .octo-style-column {
    background: rgba(255,255,255,.035);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 18px;
    padding: 18px;
  }

  .octo-builder-hero .octo-style-column h3 {
    margin: 0 0 14px;
    color: #fff;
    font-size: 18px;
    line-height: 1.2;
  }

  .octo-builder-hero .octo-style-list {
    display: grid;
    gap: 10px;
  }

  .octo-builder-hero .octo-style-point {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    color: rgba(255,255,255,.82);
    font-size: 14px;
    line-height: 1.35;
  }

  .octo-builder-hero .octo-style-point span {
    color: #ff8a35;
    font-weight: 900;
    flex-shrink: 0;
  }

  .octo-builder-hero .octo-price {
    font-size: 22px;
    font-weight: 900;
    margin: 8px 0 20px;
  }

  .octo-builder-hero .octo-note {
    color: rgba(255,255,255,.55);
    font-size: 13px;
    margin-top: 14px;
  }

  @media screen and (max-width: 900px) {
    .octo-builder-hero {
      padding: 48px 16px 40px;
    }

    .octo-builder-hero .octo-hero {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .octo-builder-hero .octo-hero-copy {
      text-align: center;
    }

    .octo-builder-hero .octo-hero-copy > p {
      margin-left: auto;
      margin-right: auto;
    }

    .octo-builder-hero .octo-style-features {
      grid-template-columns: 1fr;
    }

    .octo-builder-hero .octo-style-column {
      padding: 16px;
      text-align: left;
    }

    .octo-builder-hero .octo-float {
      position: relative;
      right: auto;
      bottom: auto;
      width: 92%;
      margin: -34px auto 0;
    }
  }
</style>

{% schema %}
{
  "name": "Octo Builder Hero",
  "settings": [
    {
      "type": "text",
      "id": "octo_eyebrow",
      "label": "Eyebrow",
      "default": "Two Patch Styles"

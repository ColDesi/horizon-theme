{% comment %}
  OctoPatches - Product Comparison Cards
  Desktop: two cards side by side
  Each card: 40% text / 60% image
  Mobile: text then image, stacked
{% endcomment %}

<section
  id="octo-product-compare-{{ section.id }}"
  class="octo-product-compare"
  style="
    --section-bg: {{ section.settings.section_bg }};
    --card-bg: {{ section.settings.card_bg }};
    --card-border: {{ section.settings.card_border }};
    --text-color: {{ section.settings.text_color }};
    --muted-color: {{ section.settings.muted_color }};
    --patch-accent: {{ section.settings.patch_accent }};
    --flex-accent: {{ section.settings.flex_accent }};
    --max-width: {{ section.settings.max_width }}px;
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="octo-product-compare__inner">

    {% if section.settings.eyebrow != blank %}
      <p class="octo-product-compare__eyebrow">
        {{ section.settings.eyebrow }}
      </p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="octo-product-compare__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.intro != blank %}
      <div class="octo-product-compare__intro rte">
        {{ section.settings.intro }}
      </div>
    {% endif %}

    <div class="octo-product-compare__cards">

      <article class="octo-product-compare__card octo-product-compare__card--patch">
        <div class="octo-product-compare__text">
          {% if section.settings.patch_label != blank %}
            <p class="octo-product-compare__label">
              {{ section.settings.patch_label }}
            </p>
          {% endif %}

          {% if section.settings.patch_heading != blank %}
            <h3 class="octo-product-compare__card-heading">
              {{ section.settings.patch_heading }}
            </h3>
          {% endif %}

          {% if section.settings.patch_description != blank %}
            <div class="octo-product-compare__description rte">
              {{ section.settings.patch_description }}
            </div>
          {% endif %}

          <ul class="octo-product-compare__points" role="list">
            {% for i in (1..4) %}
              {% assign point_key = 'patch_point_' | append: i %}
              {% assign point = section.settings[point_key] %}
              {% if point != blank %}
                <li>
                  <span class="octo-product-compare__check" aria-hidden="true">✓</span>
                  <span>{{ point }}</span>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>

        <div class="octo-product-compare__image">
          {% if section.settings.patch_image != blank %}
            <img
              src="{{ section.settings.patch_image | image_url: width: 1600 }}"
              srcset="
                {{ section.settings.patch_image | image_url: width: 600 }} 600w,
                {{ section.settings.patch_image | image_url: width: 900 }} 900w,
                {{ section.settings.patch_image | image_url: width: 1200 }} 1200w,
                {{ section.settings.patch_image | image_url: width: 1600 }} 1600w
              "
              sizes="(max-width: 749px) 100vw, 30vw"
              alt="{{ section.settings.patch_image.alt | default: section.settings.patch_heading | escape }}"
              loading="lazy"
              width="{{ section.settings.patch_image.width }}"
              height="{{ section.settings.patch_image.height }}"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'octo-product-compare__placeholder' }}
          {% endif %}
        </div>
      </article>

      <article class="octo-product-compare__card octo-product-compare__card--flex">
        <div class="octo-product-compare__text">
          {% if section.settings.flex_label != blank %}
            <p class="octo-product-compare__label">
              {{ section.settings.flex_label }}
            </p>
          {% endif %}

          {% if section.settings.flex_heading != blank %}
            <h3 class="octo-product-compare__card-heading">
              {{ section.settings.flex_heading }}
            </h3>
          {% endif %}

          {% if section.settings.flex_description != blank %}
            <div class="octo-product-compare__description rte">
              {{ section.settings.flex_description }}
            </div>
          {% endif %}

          <ul class="octo-product-compare__points" role="list">
            {% for i in (1..4) %}
              {% assign point_key = 'flex_point_' | append: i %}
              {% assign point = section.settings[point_key] %}
              {% if point != blank %}
                <li>
                  <span class="octo-product-compare__check" aria-hidden="true">✓</span>
                  <span>{{ point }}</span>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>

        <div class="octo-product-compare__image">
          {% if section.settings.flex_image != blank %}
            <img
              src="{{ section.settings.flex_image | image_url: width: 1600 }}"
              srcset="
                {{ section.settings.flex_image | image_url: width: 600 }} 600w,
                {{ section.settings.flex_image | image_url: width: 900 }} 900w,
                {{ section.settings.flex_image | image_url: width: 1200 }} 1200w,
                {{ section.settings.flex_image | image_url: width: 1600 }} 1600w
              "
              sizes="(max-width: 749px) 100vw, 30vw"
              alt="{{ section.settings.flex_image.alt | default: section.settings.flex_heading | escape }}"
              loading="lazy"
              width="{{ section.settings.flex_image.width }}"
              height="{{ section.settings.flex_image.height }}"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'octo-product-compare__placeholder' }}
          {% endif %}
        </div>
      </article>

    </div>

    {% if section.settings.cta_text != blank and section.settings.cta_link != blank %}
      <div class="octo-product-compare__cta-box">
        <div class="octo-product-compare__cta-copy">
          {% if section.settings.cta_heading != blank %}
            <strong>{{ section.settings.cta_heading }}</strong>
          {% endif %}
          {% if section.settings.cta_subtext != blank %}
            <span>{{ section.settings.cta_subtext }}</span>
          {% endif %}
        </div>

        <a
          class="octo-product-compare__cta-link"
          href="{{ section.settings.cta_link }}"
        >
          {{ section.settings.cta_text }}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
  #octo-product-compare-{{ section.id }} {
    background: var(--section-bg);
    color: var(--text-color);
    padding: var(--padding-top) 20px var(--padding-bottom);
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__inner {
    width: min(100%, var(--max-width));
    margin: 0 auto;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__eyebrow {
    margin: 0 0 10px;
    color: var(--patch-accent);
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-align: center;
    text-transform: uppercase;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__heading {
    margin: 0;
    color: var(--text-color);
    font-size: clamp(36px, 4vw, 64px);
    line-height: 1.02;
    text-align: center;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__intro {
    max-width: 820px;
    margin: 18px auto 36px;
    color: var(--muted-color);
    font-size: clamp(17px, 1.5vw, 22px);
    line-height: 1.5;
    text-align: center;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__intro > *:first-child,
  #octo-product-compare-{{ section.id }} .octo-product-compare__description > *:first-child {
    margin-top: 0;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__intro > *:last-child,
  #octo-product-compare-{{ section.id }} .octo-product-compare__description > *:last-child {
    margin-bottom: 0;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__card {
    display: grid;
    grid-template-columns: minmax(0, 40%) minmax(0, 60%);
    overflow: hidden;
    min-height: 560px;
    border: 1px solid var(--card-border);
    border-radius: 22px;
    background: var(--card-bg);
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__card--patch {
    box-shadow: inset 4px 0 0 var(--patch-accent);
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__card--flex {
    box-shadow: inset 4px 0 0 var(--flex-accent);
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(28px, 2.5vw, 46px);
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__label {
    margin: 0 0 16px;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__card--patch .octo-product-compare__label,
  #octo-product-compare-{{ section.id }} .octo-product-compare__card--patch .octo-product-compare__check {
    color: var(--patch-accent);
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__card--flex .octo-product-compare__label,
  #octo-product-compare-{{ section.id }} .octo-product-compare__card--flex .octo-product-compare__check {
    color: var(--flex-accent);
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__card-heading {
    margin: 0 0 18px;
    color: var(--text-color);
    font-size: clamp(30px, 2.5vw, 44px);
    line-height: 1.08;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__description {
    color: var(--muted-color);
    font-size: 17px;
    line-height: 1.55;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__points {
    display: grid;
    gap: 16px;
    margin: 28px 0 0;
    padding: 0;
    list-style: none;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__points li {
    display: grid;
    grid-template-columns: 22px 1fr;
    gap: 10px;
    align-items: start;
    font-size: 16px;
    line-height: 1.4;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__check {
    font-weight: 900;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__image {
    min-width: 0;
    background: #090909;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__image img,
  #octo-product-compare-{{ section.id }} .octo-product-compare__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 560px;
    object-fit: cover;
    object-position: center;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__cta-box {
    display: flex;
    gap: 28px;
    align-items: center;
    justify-content: space-between;
    max-width: 980px;
    margin: 28px auto 0;
    padding: 22px 26px;
    border: 1px solid var(--card-border);
    border-radius: 16px;
    background: var(--card-bg);
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__cta-copy {
    display: grid;
    gap: 4px;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__cta-copy strong {
    color: var(--text-color);
    font-size: 18px;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__cta-copy span {
    color: var(--muted-color);
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__cta-link {
    display: inline-flex;
    flex: 0 0 auto;
    gap: 12px;
    align-items: center;
    justify-content: center;
    color: var(--patch-accent);
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }

  #octo-product-compare-{{ section.id }} .octo-product-compare__cta-link:hover {
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  @media screen and (max-width: 1199px) {
    #octo-product-compare-{{ section.id }} .octo-product-compare__cards {
      grid-template-columns: 1fr;
    }

    #octo-product-compare-{{ section.id }} .octo-product-compare__card {
      grid-template-columns: 38% 62%;
    }
  }

  @media screen and (max-width: 749px) {
    #octo-product-compare-{{ section.id }} {
      padding-left: 14px;
      padding-right: 14px;
    }

    #octo-product-compare-{{ section.id }} .octo-product-compare__cards {
      gap: 18px;
    }

    #octo-product-compare-{{ section.id }} .octo-product-compare__card {
      grid-template-columns: 1fr;
      min-height: auto;
      border-radius: 16px;
    }

    #octo-product-compare-{{ section.id }} .octo-product-compare__text {
      padding: 30px 24px;
    }

    #octo-product-compare-{{ section.id }} .octo-product-compare__image img,
    #octo-product-compare-{{ section.id }} .octo-product-compare__placeholder {
      min-height: 0;
      height: auto;
      aspect-ratio: 4 / 5;
      object-fit: cover;
    }

    #octo-product-compare-{{ section.id }} .octo-product-compare__cta-box {
      align-items: flex-start;
      flex-direction: column;
      padding: 22px;
    }
  }
</style>

